# Copy to .env for local runs (do NOT commit real secrets).
# On Render, set these in the dashboard instead.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Each source gets its own key so any one can be revoked independently.
# Zapier is your main (and, for now, only) source.
WEBHOOK_KEYS={"zapier":"long-random-string-here"}

# Only these sources may assert contact.trusted == "Yes" (eligible for auto-send).
# Any other/unknown source is forced to manual-approval and can never auto-send.
TRUSTED_SOURCES=zapier

HERMES_MODEL=claude-sonnet-4-5
PORT=8080

# LOCAL DEV ONLY — never set this in production:
# ALLOW_UNAUTHENTICATED=true
